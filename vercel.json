{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.rutina.al" }],
      "destination": "https://rutina.al/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-meal-photos",
      "schedule": "0 3 * * *"
    }
  ]
}
